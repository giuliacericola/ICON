    <!-- http://www.semanticweb.org/icon/super_heroes#Leader -->

    <owl:Class rdf:about="http://www.semanticweb.org/icon/super_heroes#Leader">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/icon/super_heroes#Character"/>
